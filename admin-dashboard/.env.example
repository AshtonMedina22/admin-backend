# Private Google Sheets API access.
# The workbook does not need to be published to the web.

GOOGLE_SHEET_ID=1WAJWr2omEayubh_Ty6Gv_XIuWQCcBLYA5scLr4Nlv2g

# Local Windows development option:
# 1. Download a Google Cloud service-account JSON key.
# 2. Save it as ./google-service-account.json.
# 3. Share the workbook with the service account's client_email as Viewer or Editor.
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# Vercel option:
# Paste the full service-account JSON as one line instead of using a local file.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Demo-friendly workbook connector:
# Deploy the bound Apps Script as a web app returning clean JSON.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
